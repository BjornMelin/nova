{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "additionalProperties": false,
        "description": "Health check response payload.",
        "properties": {
          "request_id": {
            "title": "Request Id",
            "type": "string"
          },
          "service": {
            "const": "nova-auth-api",
            "title": "Service",
            "type": "string"
          },
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "service",
          "request_id"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "Principal": {
        "additionalProperties": false,
        "description": "Authorized caller identity resolved from token claims.",
        "properties": {
          "permissions": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Permissions",
            "type": "array"
          },
          "scope_id": {
            "title": "Scope Id",
            "type": "string"
          },
          "scopes": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Scopes",
            "type": "array"
          },
          "subject": {
            "title": "Subject",
            "type": "string"
          },
          "tenant_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tenant Id"
          }
        },
        "required": [
          "subject",
          "scope_id"
        ],
        "title": "Principal",
        "type": "object"
      },
      "TokenIntrospectFormRequest": {
        "additionalProperties": false,
        "description": "Request payload for token introspection.",
        "properties": {
          "access_token": {
            "minLength": 1,
            "title": "Access Token",
            "type": "string"
          },
          "required_permissions": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Required Permissions",
            "type": "array"
          },
          "required_scopes": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Required Scopes",
            "type": "array"
          }
        },
        "required": [
          "access_token"
        ],
        "title": "TokenIntrospectFormRequest",
        "type": "object"
      },
      "TokenIntrospectRequest": {
        "additionalProperties": false,
        "description": "Request payload for token introspection.",
        "properties": {
          "access_token": {
            "minLength": 1,
            "title": "Access Token",
            "type": "string"
          },
          "required_permissions": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Required Permissions",
            "type": "array"
          },
          "required_scopes": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Required Scopes",
            "type": "array"
          }
        },
        "required": [
          "access_token"
        ],
        "title": "TokenIntrospectRequest",
        "type": "object"
      },
      "TokenIntrospectResponse": {
        "additionalProperties": false,
        "description": "Response payload for token introspection.",
        "properties": {
          "active": {
            "title": "Active",
            "type": "boolean"
          },
          "claims": {
            "additionalProperties": true,
            "title": "Claims",
            "type": "object"
          },
          "principal": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Principal"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "active"
        ],
        "title": "TokenIntrospectResponse",
        "type": "object"
      },
      "TokenVerifyRequest": {
        "additionalProperties": false,
        "description": "Request payload for access token verification.",
        "properties": {
          "access_token": {
            "minLength": 1,
            "title": "Access Token",
            "type": "string"
          },
          "required_permissions": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Required Permissions",
            "type": "array"
          },
          "required_scopes": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Required Scopes",
            "type": "array"
          }
        },
        "required": [
          "access_token"
        ],
        "title": "TokenVerifyRequest",
        "type": "object"
      },
      "TokenVerifyResponse": {
        "additionalProperties": false,
        "description": "Response payload for token verification.",
        "properties": {
          "claims": {
            "additionalProperties": true,
            "title": "Claims",
            "type": "object"
          },
          "principal": {
            "$ref": "#/components/schemas/Principal"
          }
        },
        "required": [
          "principal",
          "claims"
        ],
        "title": "TokenVerifyResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "nova-auth-api",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/health/live": {
      "get": {
        "description": "Return liveness status.",
        "operationId": "health_live",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health Live",
        "tags": [
          "health"
        ]
      }
    },
    "/v1/health/ready": {
      "get": {
        "description": "Return readiness status for token verification.",
        "operationId": "health_ready",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health Ready",
        "tags": [
          "health"
        ]
      }
    },
    "/v1/token/introspect": {
      "post": {
        "description": "Introspect token and return active status plus claim details.",
        "operationId": "introspect_token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenIntrospectRequest"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/TokenIntrospectFormRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenIntrospectResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Introspect Token",
        "tags": [
          "token"
        ]
      }
    },
    "/v1/token/verify": {
      "post": {
        "description": "Verify access token and return principal plus claims.",
        "operationId": "verify_token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenVerifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenVerifyResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Verify Token",
        "tags": [
          "token"
        ]
      }
    }
  }
}
