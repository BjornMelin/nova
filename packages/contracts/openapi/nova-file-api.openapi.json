            "title": "Urls",
            "type": "object"
          }
        },
        "required": [
          "expires_in_seconds",
          "urls"
        ],
        "title": "SignPartsResponse",
        "type": "object"
      },
      "UploadStrategy": {
        "description": "Upload strategy options returned by initiate endpoint.",
        "enum": [
          "single",
          "multipart"
        ],
        "title": "UploadStrategy",
        "type": "string"
      }
    }
