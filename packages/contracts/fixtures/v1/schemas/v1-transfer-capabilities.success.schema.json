{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "policy_version",
    "max_upload_bytes",
    "multipart_threshold_bytes",
    "target_upload_part_count",
    "minimum_part_size_bytes",
    "maximum_part_size_bytes",
    "max_concurrency_hint",
    "sign_batch_size_hint",
    "accelerate_enabled",
    "checksum_mode",
    "active_multipart_upload_limit",
    "daily_ingress_budget_bytes",
    "sign_requests_per_upload_limit",
    "large_export_worker_threshold_bytes",
    "resumable_ttl_seconds"
  ],
  "properties": {
    "policy_id": { "type": "string" },
    "policy_version": { "type": "string" },
    "max_upload_bytes": { "type": "integer", "minimum": 1 },
    "multipart_threshold_bytes": { "type": "integer", "minimum": 1 },
    "target_upload_part_count": { "type": "integer", "minimum": 1 },
    "minimum_part_size_bytes": { "type": "integer", "minimum": 1 },
    "maximum_part_size_bytes": { "type": "integer", "minimum": 1 },
    "max_concurrency_hint": { "type": "integer", "minimum": 1 },
    "sign_batch_size_hint": { "type": "integer", "minimum": 1 },
    "accelerate_enabled": { "type": "boolean" },
    "checksum_algorithm": { "type": ["string", "null"] },
    "checksum_mode": { "type": "string", "enum": ["none", "optional", "required"] },
    "resumable_ttl_seconds": { "type": "integer", "minimum": 1 }
    ,
    "active_multipart_upload_limit": { "type": "integer", "minimum": 1 },
    "daily_ingress_budget_bytes": { "type": "integer", "minimum": 1 },
    "sign_requests_per_upload_limit": { "type": "integer", "minimum": 1 },
    "large_export_worker_threshold_bytes": { "type": "integer", "minimum": 1 }
  }
}
