{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "policy_version",
    "max_upload_bytes",
    "multipart_threshold_bytes",
    "target_upload_part_count",
    "minimum_part_size_bytes",
    "maximum_part_size_bytes",
    "max_concurrency_hint",
    "sign_batch_size_hint",
    "accelerate_enabled",
    "resumable_ttl_seconds"
  ],
  "properties": {
    "policy_id": { "type": "string" },
    "policy_version": { "type": "string" },
    "max_upload_bytes": { "type": "integer" },
    "multipart_threshold_bytes": { "type": "integer" },
    "target_upload_part_count": { "type": "integer" },
    "minimum_part_size_bytes": { "type": "integer" },
    "maximum_part_size_bytes": { "type": "integer" },
    "max_concurrency_hint": { "type": "integer" },
    "sign_batch_size_hint": { "type": "integer" },
    "accelerate_enabled": { "type": "boolean" },
    "checksum_algorithm": { "type": ["string", "null"] },
    "resumable_ttl_seconds": { "type": "integer" }
  }
}
