{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan"],
  "properties": {
    "plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource", "supported", "reason"],
        "properties": {
          "resource": {"type": "string"},
          "supported": {"type": "boolean"},
          "reason": {"type": ["string", "null"]}
        }
      }
    }
  }
}
