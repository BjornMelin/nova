{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nova/contracts/fixtures/v1/schemas/auth-verify.success.schema.json",
  "title": "AuthVerifySuccessResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["principal", "claims"],
  "properties": {
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "scope_id", "tenant_id", "scopes", "permissions"],
      "properties": {
        "subject": { "type": "string", "minLength": 1 },
        "scope_id": { "type": "string", "minLength": 1 },
        "tenant_id": { "type": ["string", "null"] },
        "scopes": { "type": "array", "items": { "type": "string" } },
        "permissions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "claims": {
      "type": "object",
      "required": ["iss", "aud", "sub", "exp"],
      "properties": {
        "iss": { "type": "string" },
        "aud": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "sub": { "type": "string" },
        "exp": { "type": "integer" }
      }
    }
  }
}
