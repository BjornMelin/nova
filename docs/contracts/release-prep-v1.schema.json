{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/release-prep-v1.schema.json",
  "title": "Committed release prep artifact",
  "description": "Canonical machine-readable release intent committed in the repository before merge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prepared_at",
    "prepared_from_commit",
    "base_commit",
    "head_commit",
    "first_release",
    "changed_files",
    "changed_units",
    "global_bump",
    "units"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "prepared_at": {
      "type": "string",
      "format": "date-time"
    },
    "prepared_from_commit": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "base_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "head_commit": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "first_release": {
      "type": "boolean"
    },
    "global_bump": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "major",
        "minor",
        "patch",
        null
      ]
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changed_units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "unit_id"
        ],
        "properties": {
          "unit_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "unit_id",
          "new_version"
        ],
        "properties": {
          "unit_id": {
            "type": "string",
            "minLength": 1
          },
          "new_version": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
