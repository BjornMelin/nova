{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/workflow-post-deploy-validate.schema.json",
  "title": "Reusable Post Deploy Validate workflow_call contract",
  "description": "Contract for reusable post-deploy route validation workflow inputs and outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "inputs",
    "outputs"
  ],
  "properties": {
    "inputs": {
      "type": "object",
      "description": "Inputs passed into reusable-post-deploy-validate workflow_call.",
      "additionalProperties": false,
      "properties": {
        "deploy_run_id": {
          "type": "string",
          "description": "Workflow run id that produced the authoritative deploy-output artifact.",
          "pattern": "^[1-9][0-9]*$"
        },
        "deploy_repo": {
          "type": "string",
          "description": "Repository that owns the deploy-output artifact.",
          "pattern": "^$|^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
          "default": ""
        },
        "deploy_artifact_name": {
          "type": "string",
          "description": "Artifact name containing deploy-output.json and deploy-output.sha256.",
          "default": "deploy-runtime-output",
          "minLength": 1
        },
        "deploy_output_json": {
          "type": "string",
          "description": "Optional inline deploy-output JSON payload.",
          "default": ""
        },
        "deploy_output_path": {
          "type": "string",
          "description": "Optional workspace path to a pre-fetched deploy-output JSON file.",
          "pattern": "^$|^[^\\s]+\\.json$",
          "default": ""
        },
        "validation_canonical_paths": {
          "type": "string",
          "pattern": "^/.+",
          "description": "Comma-delimited canonical paths."
        },
        "validation_legacy_404_paths": {
          "type": "string",
          "pattern": "^/.+",
          "description": "Comma-delimited legacy paths that must return 404."
        },
        "report_path": {
          "type": "string",
          "pattern": "^[^\\s]+\\.json$",
          "default": "post-deploy-validation-report.json"
        },
        "artifact_name": {
          "type": "string",
          "minLength": 1,
          "default": "post-deploy-validation-report"
        }
      },
      "anyOf": [
        {
          "required": [
            "deploy_run_id"
          ]
        },
        {
          "required": ["deploy_output_json"],
          "properties": {
            "deploy_output_json": {
              "minLength": 1
            }
          }
        },
        {
          "required": ["deploy_output_path"],
          "properties": {
            "deploy_output_path": {
              "minLength": 1
            }
          }
        }
      ]
    },
    "outputs": {
      "type": "object",
      "description": "Outputs emitted by reusable-post-deploy-validate workflow_call.",
      "additionalProperties": false,
      "required": [
        "validation_status",
        "report_path",
        "artifact_name"
      ],
      "properties": {
        "validation_status": {
          "type": "string",
          "enum": [
            "passed",
            "failed"
          ]
        },
        "report_path": {
          "type": "string",
          "pattern": "^[^\\s]+\\.json$"
        },
        "artifact_name": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
