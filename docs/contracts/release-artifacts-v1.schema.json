{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/release-artifacts-v1.schema.json",
  "title": "Release artifact contracts",
  "description": "Schema for release artifacts emitted by staged publish/promotion and post-deploy validation workflows, including promotion payload SHA256 evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "changed_units",
    "version_plan",
    "codeartifact_gate_report",
    "codeartifact_promotion_candidates",
    "promotion_input_digests",
    "post_deploy_validation_report"
  ],
  "properties": {
    "changed_units": {
      "$ref": "#/$defs/changed_units"
    },
    "version_plan": {
      "$ref": "#/$defs/version_plan"
    },
    "codeartifact_gate_report": {
      "$ref": "#/$defs/codeartifact_gate_report"
    },
    "codeartifact_promotion_candidates": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/promotion_candidate"
      }
    },
    "promotion_input_digests": {
      "$ref": "#/$defs/promotion_input_digests"
    },
    "post_deploy_validation_report": {
      "$ref": "#/$defs/post_deploy_validation_report"
    },
    "browser_live_validation_report": {
      "$ref": "#/$defs/browser_live_validation_report"
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "sha256_digest": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "promotion_input_digests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed_units_sha256",
        "version_plan_sha256",
        "promotion_candidates_sha256"
      ],
      "properties": {
        "changed_units_sha256": {
          "$ref": "#/$defs/sha256_digest"
        },
        "version_plan_sha256": {
          "$ref": "#/$defs/sha256_digest"
        },
        "promotion_candidates_sha256": {
          "$ref": "#/$defs/sha256_digest"
        }
      }
    },
    "workspace_unit_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit_id",
        "project",
        "path",
        "format",
        "codeartifact_format"
      ],
      "properties": {
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "pypi",
            "npm",
            "r"
          ]
        },
        "codeartifact_format": {
          "type": "string",
          "enum": [
            "pypi",
            "npm",
            "generic"
          ]
        },
        "namespace": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "format": {
                "const": "pypi"
              }
            }
          },
          "then": {
            "properties": {
              "codeartifact_format": {
                "const": "pypi"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "format": {
                "const": "npm"
              }
            }
          },
          "then": {
            "properties": {
              "codeartifact_format": {
                "const": "npm"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "format": {
                "const": "r"
              }
            }
          },
          "then": {
            "properties": {
              "codeartifact_format": {
                "const": "generic"
              }
            }
          }
        }
      ]
    },
    "changed_units": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "generated_at",
        "base_commit",
        "head_commit",
        "first_release",
        "changed_files",
        "changed_units"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "base_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "head_commit": {
          "type": "string",
          "minLength": 1
        },
        "first_release": {
          "type": "boolean"
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "changed_units": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "unit_id",
              "project",
              "path",
              "version",
              "format",
              "codeartifact_format",
              "namespace"
            ],
            "properties": {
              "unit_id": {
                "type": "string",
                "minLength": 1
              },
              "project": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "$ref": "#/$defs/semver"
              },
              "format": {
                "type": "string",
                "enum": [
                  "pypi",
                  "npm",
                  "r"
                ]
              },
              "codeartifact_format": {
                "type": "string",
                "enum": [
                  "pypi",
                  "npm",
                  "generic"
                ]
              },
              "namespace": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "format": {
                      "const": "pypi"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "codeartifact_format": {
                      "const": "pypi"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "format": {
                      "const": "npm"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "codeartifact_format": {
                      "const": "npm"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "format": {
                      "const": "r"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "codeartifact_format": {
                      "const": "generic"
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "version_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "generated_at",
        "base_commit",
        "head_commit",
        "global_bump",
        "units"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "base_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "head_commit": {
          "type": "string",
          "minLength": 1
        },
        "global_bump": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "major",
            "minor",
            "patch",
            null
          ]
        },
        "units": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "unit_id",
              "project",
              "path",
              "format",
              "codeartifact_format",
              "namespace",
              "old_version",
              "new_version",
              "bump",
              "reason"
            ],
            "properties": {
              "unit_id": {
                "type": "string",
                "minLength": 1
              },
              "project": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "format": {
                "type": "string",
                "enum": [
                  "pypi",
                  "npm",
                  "r"
                ]
              },
              "codeartifact_format": {
                "type": "string",
                "enum": [
                  "pypi",
                  "npm",
                  "generic"
                ]
              },
              "namespace": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "old_version": {
                "$ref": "#/$defs/semver"
              },
              "new_version": {
                "$ref": "#/$defs/semver"
              },
              "bump": {
                "type": "string",
                "enum": [
                  "major",
                  "minor",
                  "patch"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "format": {
                      "const": "pypi"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "codeartifact_format": {
                      "const": "pypi"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "format": {
                      "const": "npm"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "codeartifact_format": {
                      "const": "npm"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "format": {
                      "const": "r"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "codeartifact_format": {
                      "const": "generic"
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "promotion_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "codeartifact_format",
        "namespace",
        "package",
        "version",
        "unit_id"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "pypi",
            "npm",
            "r"
          ]
        },
        "codeartifact_format": {
          "type": "string",
          "enum": [
            "pypi",
            "npm",
            "generic"
          ]
        },
        "namespace": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "package": {
          "type": "string",
          "pattern": "^(@[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*|nova-[a-z0-9][a-z0-9-]*|[a-z0-9][a-z0-9._-]{0,254})$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "tarball_sha256": {
          "$ref": "#/$defs/sha256_digest"
        },
        "signature_sha256": {
          "$ref": "#/$defs/sha256_digest"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "format": {
                "const": "pypi"
              }
            }
          },
          "then": {
            "properties": {
              "namespace": {
                "type": "null"
              },
              "package": {
                "pattern": "^nova-[a-z0-9][a-z0-9-]*$"
              },
              "codeartifact_format": {
                "const": "pypi"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "format": {
                "const": "npm"
              }
            }
          },
          "then": {
            "properties": {
              "namespace": {
                "type": "string",
                "const": "nova"
              },
              "package": {
                "pattern": "^@nova/[a-z0-9][a-z0-9-]*$"
              },
              "codeartifact_format": {
                "const": "npm"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "format": {
                "const": "r"
              }
            }
          },
          "then": {
            "required": [
              "tarball_sha256",
              "signature_sha256"
            ],
            "properties": {
              "namespace": {
                "type": "string",
                "const": "nova"
              },
              "package": {
                "pattern": "^[a-z0-9][a-z0-9._-]{0,254}$"
              },
              "tarball_sha256": {
                "$ref": "#/$defs/sha256_digest"
              },
              "signature_sha256": {
                "$ref": "#/$defs/sha256_digest"
              },
              "codeartifact_format": {
                "const": "generic"
              }
            }
          }
        }
      ]
    },
    "codeartifact_gate_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "manifest_path",
        "manifest_sha256",
        "changed_units_count",
        "planned_package_count",
        "promotion_candidates"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "changed_units_count": {
          "type": "integer",
          "minimum": 0
        },
        "planned_package_count": {
          "type": "integer",
          "minimum": 0
        },
        "promotion_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/promotion_candidate"
          }
        }
      }
    },
    "route_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "method",
        "path",
        "expected",
        "status_code",
        "ok"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "canonical",
            "cors_preflight",
            "protected",
            "execute_api_disabled",
            "legacy_404"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/[^\\s]*$"
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "type": "string",
          "minLength": 1
        },
        "status_code": {
          "type": "integer",
          "minimum": 0
        },
        "ok": {
          "type": "boolean"
        }
      }
    },
    "runtime_release_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "environment"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "post_deploy_validation_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp_utc",
        "base_url",
        "execute_api_endpoint",
        "canonical_paths",
        "protected_paths",
        "legacy_404_paths",
        "cors_preflight_path",
        "cors_allowed_origins",
        "cors_origin",
        "checks",
        "status",
        "failures",
        "deploy_output_sha256",
        "release_commit_sha",
        "runtime_version",
        "release_info"
      ],
      "properties": {
        "timestamp_utc": {
          "type": "string",
          "format": "date-time"
        },
        "base_url": {
          "type": "string",
          "pattern": "^https://.+$"
        },
        "execute_api_endpoint": {
          "type": "string",
          "pattern": "^https://.+\\.execute-api\\..+$"
        },
        "canonical_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^/[^\\s]*$"
          }
        },
        "protected_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+\\s+/[^\\s]*$"
          }
        },
        "legacy_404_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^/[^\\s]*$"
          }
        },
        "cors_preflight_path": {
          "type": "string",
          "pattern": "^/[^\\s]*$"
        },
        "cors_allowed_origins": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cors_origin": {
          "type": "string",
          "pattern": "^https?://.+$"
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/route_check"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed"
          ]
        },
        "failures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deploy_output_sha256": {
          "$ref": "#/$defs/sha256_digest"
        },
        "release_commit_sha": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{40}$"
        },
        "runtime_version": {
          "type": "string",
          "minLength": 1
        },
        "release_info": {
          "$ref": "#/$defs/runtime_release_info"
        }
      }
    },
    "browser_live_validation_report": {
      "$ref": "browser-live-validation-report.schema.json"
    }
  }
}
