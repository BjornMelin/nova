{
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/deploy-output-authority-v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Authoritative runtime deployment artifact emitted by the deploy-runtime workflow.",
  "properties": {
    "api_lambda_artifact": {
      "additionalProperties": true,
      "properties": {
        "artifact_bucket": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_key": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[A-Fa-f0-9]{64}$",
          "type": "string"
        },
        "package_name": {
          "minLength": 1,
          "type": "string"
        },
        "package_version": {
          "minLength": 1,
          "type": "string"
        },
        "release_commit_sha": {
          "pattern": "^[A-Fa-f0-9]{40}$",
          "type": "string"
        }
      },
      "required": [
        "artifact_bucket",
        "artifact_key",
        "artifact_sha256",
        "package_name",
        "package_version",
        "release_commit_sha"
      ],
      "type": "object"
    },
    "captured_at": {
      "format": "date-time",
      "type": "string"
    },
    "deploy_run_attempt": {
      "minimum": 1,
      "type": "integer"
    },
    "deploy_run_id": {
      "minimum": 1,
      "type": "integer"
    },
    "deploy_workflow_ref": {
      "minLength": 1,
      "type": "string"
    },
    "environment": {
      "minLength": 1,
      "type": "string"
    },
    "public_base_url": {
      "pattern": "^https://.+$",
      "type": "string"
    },
    "region": {
      "pattern": "^[a-z]{2}-[a-z]+-\\d+$",
      "type": "string"
    },
    "release_commit_sha": {
      "pattern": "^[A-Fa-f0-9]{40}$",
      "type": "string"
    },
    "repository": {
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "runtime_name": {
      "minLength": 1,
      "type": "string"
    },
    "runtime_version": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "2.0",
      "type": "string"
    },
    "stack_id": {
      "minLength": 1,
      "type": "string"
    },
    "stack_name": {
      "minLength": 1,
      "type": "string"
    },
    "stack_outputs": {
      "additionalProperties": {
        "minLength": 1,
        "type": "string"
      },
      "minProperties": 1,
      "properties": {
        "NovaPublicBaseUrl": {
          "pattern": "^https://.+$",
          "type": "string"
        }
      },
      "required": [
        "NovaPublicBaseUrl"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "captured_at",
    "repository",
    "deploy_run_id",
    "deploy_run_attempt",
    "deploy_workflow_ref",
    "stack_name",
    "region",
    "environment",
    "runtime_name",
    "runtime_version",
    "release_commit_sha",
    "public_base_url",
    "stack_outputs",
    "api_lambda_artifact"
  ],
  "title": "Runtime deploy-output authority",
  "type": "object"
}
