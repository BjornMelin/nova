{
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/deploy-output-authority-v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Authoritative runtime deployment artifact emitted by the AWS-native release control plane.",
  "properties": {
    "api_lambda_artifact": {
      "additionalProperties": false,
      "properties": {
        "artifact_bucket": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_key": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[A-Fa-f0-9]{64}$",
          "type": "string"
        },
        "package_name": {
          "minLength": 1,
          "type": "string"
        },
        "package_version": {
          "minLength": 1,
          "type": "string"
        },
        "release_commit_sha": {
          "pattern": "^[A-Fa-f0-9]{40}$",
          "type": "string"
        }
      },
      "required": [
        "artifact_bucket",
        "artifact_key",
        "artifact_sha256",
        "package_name",
        "package_version",
        "release_commit_sha"
      ],
      "type": "object"
    },
    "captured_at": {
      "format": "date-time",
      "type": "string"
    },
    "cors_allowed_origins": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "environment": {
      "minLength": 1,
      "type": "string"
    },
    "execute_api_endpoint": {
      "pattern": "^https://.+\\.execute-api\\..+$",
      "type": "string"
    },
    "execution": {
      "additionalProperties": false,
      "properties": {
        "codebuild_build_ids": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "pipeline_execution_id": {
          "minLength": 1,
          "type": "string"
        },
        "pipeline_name": {
          "minLength": 1,
          "type": "string"
        },
        "system": {
          "const": "aws-codepipeline",
          "type": "string"
        }
      },
      "required": [
        "system",
        "pipeline_name",
        "pipeline_execution_id"
      ],
      "type": "object"
    },
    "public_base_url": {
      "pattern": "^https://.+$",
      "type": "string"
    },
    "region": {
      "pattern": "^[a-z]{2}-[a-z]+-\\d+$",
      "type": "string"
    },
    "release_commit_sha": {
      "pattern": "^[A-Fa-f0-9]{40}$",
      "type": "string"
    },
    "repository": {
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "runtime_name": {
      "minLength": 1,
      "type": "string"
    },
    "runtime_version": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "2.0",
      "type": "string"
    },
    "stack_id": {
      "pattern": "^arn:aws:cloudformation:[a-z0-9-]+:\\d{12}:stack/.+$",
      "type": "string"
    },
    "stack_name": {
      "minLength": 1,
      "type": "string"
    },
    "stack_outputs": {
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "NovaAlarmTopicArn": {
          "pattern": "^arn:aws:sns:[a-z0-9-]+:\\d{12}:.+$",
          "type": "string"
        },
        "NovaApiAccessLogGroupName": {
          "pattern": "^/aws/apigateway/.+$",
          "type": "string"
        },
        "NovaExportCopyPartsTableName": {
          "minLength": 1,
          "type": "string"
        },
        "NovaExportWorkflowStateMachineArn": {
          "pattern": "^arn:aws:states:[a-z0-9-]+:\\d{12}:stateMachine:.+$",
          "type": "string"
        },
        "NovaExportsTableName": {
          "minLength": 1,
          "type": "string"
        },
        "NovaIdempotencyTableName": {
          "minLength": 1,
          "type": "string"
        },
        "NovaObservabilityDashboardName": {
          "minLength": 1,
          "type": "string"
        },
        "NovaPublicBaseUrl": {
          "pattern": "^https://.+$",
          "type": "string"
        },
        "NovaRestApiEndpoint": {
          "pattern": "^https://.+\\.execute-api\\..+$",
          "type": "string"
        },
        "NovaStorageLensConfigurationId": {
          "minLength": 1,
          "type": "string"
        },
        "NovaTransferPolicyAppConfigApplicationId": {
          "minLength": 1,
          "type": "string"
        },
        "NovaTransferPolicyAppConfigEnvironmentId": {
          "minLength": 1,
          "type": "string"
        },
        "NovaTransferPolicyAppConfigProfileId": {
          "minLength": 1,
          "type": "string"
        },
        "NovaTransferSpendBudgetName": {
          "minLength": 1,
          "type": "string"
        },
        "NovaTransferUsageTableName": {
          "minLength": 1,
          "type": "string"
        },
        "NovaUploadSessionsTableName": {
          "minLength": 1,
          "type": "string"
        },
        "NovaWafLogGroupName": {
          "pattern": "^aws-waf-logs-.+$",
          "type": "string"
        }
      },
      "required": [
        "NovaPublicBaseUrl",
        "NovaRestApiEndpoint"
      ],
      "type": "object"
    },
    "workflow_lambda_artifact": {
      "additionalProperties": false,
      "properties": {
        "artifact_bucket": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_key": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[A-Fa-f0-9]{64}$",
          "type": "string"
        },
        "package_name": {
          "minLength": 1,
          "type": "string"
        },
        "package_version": {
          "minLength": 1,
          "type": "string"
        },
        "release_commit_sha": {
          "pattern": "^[A-Fa-f0-9]{40}$",
          "type": "string"
        }
      },
      "required": [
        "artifact_bucket",
        "artifact_key",
        "artifact_sha256",
        "package_name",
        "package_version",
        "release_commit_sha"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "captured_at",
    "repository",
    "execution",
    "stack_name",
    "region",
    "environment",
    "runtime_name",
    "runtime_version",
    "release_commit_sha",
    "public_base_url",
    "execute_api_endpoint",
    "cors_allowed_origins",
    "stack_outputs",
    "api_lambda_artifact",
    "workflow_lambda_artifact"
  ],
  "title": "Runtime deploy-output authority",
  "type": "object"
}
