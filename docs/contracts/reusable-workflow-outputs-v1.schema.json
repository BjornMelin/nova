{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/reusable-workflow-outputs-v1.schema.json",
  "title": "Reusable workflow outputs v1",
  "description": "Workflow-specific output contract variants for reusable workflow APIs.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/cloudformation_change_set_output"
    },
    {
      "$ref": "#/$defs/codepipeline_execution_output"
    },
    {
      "$ref": "#/$defs/validation_report_output"
    },
    {
      "$ref": "#/$defs/manifest_output"
    },
    {
      "$ref": "#/$defs/deploy_runtime_output"
    }
  ],
  "$defs": {
    "stack_name": {
      "type": "string",
      "minLength": 1
    },
    "change_set_name": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_execution_id": {
      "type": "string"
    },
    "validation_report_path": {
      "type": "string"
    },
    "manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "cloudformation_change_set_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stack_name",
        "change_set_name"
      ],
      "properties": {
        "stack_name": {
          "$ref": "#/$defs/stack_name"
        },
        "change_set_name": {
          "$ref": "#/$defs/change_set_name"
        }
      }
    },
    "codepipeline_execution_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pipeline_execution_id"
      ],
      "properties": {
        "pipeline_execution_id": {
          "$ref": "#/$defs/pipeline_execution_id"
        }
      }
    },
    "validation_report_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_report_path"
      ],
      "properties": {
        "validation_report_path": {
          "$ref": "#/$defs/validation_report_path"
        }
      }
    },
    "manifest_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_sha256"
      ],
      "properties": {
        "manifest_sha256": {
          "$ref": "#/$defs/manifest_sha256"
        }
      }
    },
    "deploy_runtime_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stack_name",
        "change_set_name",
        "pipeline_execution_id",
        "validation_report_path",
        "manifest_sha256"
      ],
      "properties": {
        "stack_name": {
          "$ref": "#/$defs/stack_name"
        },
        "change_set_name": {
          "$ref": "#/$defs/change_set_name"
        },
        "pipeline_execution_id": {
          "$ref": "#/$defs/pipeline_execution_id"
        },
        "validation_report_path": {
          "$ref": "#/$defs/validation_report_path"
        },
        "manifest_sha256": {
          "$ref": "#/$defs/manifest_sha256"
        }
      }
    }
  }
}
