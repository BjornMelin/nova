{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/reusable-workflow-inputs-v1.schema.json",
  "title": "Reusable workflow inputs v1",
  "description": "Input contract for reusable deploy-runtime workflow API.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "app_type",
    "environment",
    "stack_name",
    "template_file"
  ],
  "properties": {
    "app_type": {
      "type": "string",
      "enum": ["dash", "rshiny", "react-next"]
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "stack_name": {
      "type": "string",
      "minLength": 1
    },
    "template_file": {
      "$ref": "#/$defs/relative_file_path"
    },
    "parameter_file": {
      "type": "string",
      "default": ""
    },
    "image_tag": {
      "type": "string",
      "default": ""
    },
    "size_profile": {
      "type": "string",
      "enum": ["small", "medium", "large", "custom"],
      "default": "medium"
    },
    "enable_worker": {
      "type": "boolean",
      "default": false
    },
    "custom_container_port": {
      "type": "number",
      "minimum": 0,
      "maximum": 65535
    },
    "custom_task_cpu": {
      "type": "number",
      "minimum": 0,
      "maximum": 16384
    },
    "custom_task_memory": {
      "type": "number",
      "minimum": 0,
      "maximum": 65536
    },
    "custom_desired_count": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "approval_environment": {
      "type": "string",
      "default": ""
    },
    "aws_region": {
      "type": "string",
      "pattern": "^[a-z]{2}-[a-z]+-\\d$"
    },
    "capabilities": {
      "type": "string",
      "default": "CAPABILITY_NAMED_IAM"
    },
    "pipeline_name": {
      "type": "string",
      "default": ""
    }
  },
  "$defs": {
    "relative_file_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/).+"
    }
  }
}
