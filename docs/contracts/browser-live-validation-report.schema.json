{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3m-cloud.github.io/nova/docs/contracts/browser-live-validation-report.schema.json",
  "title": "Browser live validation report contract",
  "description": "WS5 browser/live validation gate artifact schema for dash-pca + Nova integration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "environment",
    "dash_base_url",
    "nova_base_url",
    "status",
    "failure_class",
    "checks",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "environment": {
      "type": "string",
      "enum": [
        "dev",
        "prod"
      ]
    },
    "dash_base_url": {
      "type": "string",
      "pattern": "^https://.+$"
    },
    "nova_base_url": {
      "type": "string",
      "pattern": "^https://.+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "none",
        "P0",
        "P1"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_contract_report",
        "trace",
        "screenshots",
        "network_log",
        "console_log",
        "error_log"
      ],
      "properties": {
        "route_contract_report": {
          "type": "string",
          "minLength": 1
        },
        "trace": {
          "type": "string",
          "minLength": 1
        },
        "screenshots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "network_log": {
          "type": "string",
          "minLength": 1
        },
        "console_log": {
          "type": "string",
          "minLength": 1
        },
        "error_log": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "details"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^C\\d{2}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed"
          ]
        },
        "details": {
          "type": "string"
        }
      }
    }
  }
}
